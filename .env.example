# Karaoke App
PORT=3000
NODE_ENV=development
DEFAULT_LANGUAGE=en-US
SONGLIST_PATH=./songlist.json

# Ultrastar Queing
KARAOKE_QUERY_USE_QUEUE=true
KARAOKE_QUEUE_DEFAULT_USERNAME=Unknown
ULTRASTAR_API_BASE=http://192.168.0.1:6789
ULTRASTAR_CLIENT_ID=change_me
SING_SCENE_PLAYER_DATA_DTO='{"PlayerProfileNames":["Player01"],"PlayerProfileToMicProfileMap":{"Player01":{"Name":"USB Microphone","ChannelIndex":0,"Color":"#F673A2","Amplification":0,"NoiseSuppression":5,"IsEnabled":true,"DelayInMillis":200,"SampleRate":0,"ConnectedClientId":null}},"PlayerProfileToVoiceIdMap":{"Player01":"P1","Player02":"P1","Player03":"P1","Player04":"P1"}}'

# Meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY='change_me_with_openssl rand -hex 32'
